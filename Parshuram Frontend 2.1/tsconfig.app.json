{
    "extends": "./tsconfig.json",
    "compilerOptions": {
      "composite": true,
      "target": "es2020",
      
      "useDefineForClassFields": true,
      "lib": ["ES2020", "DOM", "DOM.Iterable"] 
    },
    "include": [
      "src", 
      "src/**/*.ts", 
      "src/**/*.tsx",
      "src/**/*.js", 
      "src/**/*.jsx"
    ]
  }