{
    "compilerOptions": {
      
      "useDefineForClassFields": true,
      
      "module": "ESNext",
      "skipLibCheck": true,
      "target" : "es2020",
      "moduleResolution": "bundler",
      
      "resolveJsonModule": true,
      "isolatedModules": true,
                   
      "jsx": "react-jsx",
      "noEmit": true,
      "allowJs": true,
      "esModuleInterop": true, 

      "strict": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "noFallthroughCasesInSwitch": true
    },
    "include": ["src", 
      "src/**/*.ts", 
      "src/**/*.tsx",
      "src/**/*.js", 
      "src/**/*.jsx"],
    "references": [
      
    ]
  }